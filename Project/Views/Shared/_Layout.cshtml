<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ANDON Yönetimi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/gridstack@8.2.3/dist/gridstack.min.css" rel="stylesheet" />
    <style>
        html { font-size: 0.833vw; }
        body { background-color: #0b0d11; color: #e2e8f0; display: flex; min-height: 100vh; overflow-x: hidden; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .sidebar { min-width: 15vw; max-width: 15vw; background: linear-gradient(180deg, #111827 0%, #0f1115 100%); border-right: 0.1vw solid #1f2937; transition: all 0.3s; box-shadow: 0.5vw 0 1vw rgba(0,0,0,0.5); z-index: 10; }
        .sidebar.collapsed { margin-left: -15vw; box-shadow: none; }
        .sidebar .nav-link { color: #94a3b8; padding: 1vw 1.5vw; border-bottom: 0.1vw solid #1f2937; transition: all 0.2s; font-weight: 500; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #38bdf8; background-color: rgba(56,189,248,0.1); border-left: 0.3vw solid #38bdf8; }
        .main-content { flex: 1; padding: 1.5vw; width: 100%; transition: all 0.3s; background-color: #0b0d11; }
        .topbar { background: rgba(17,24,39,0.8); backdrop-filter: blur(10px); padding: 0.8vw 1.5vw; border-bottom: 0.1vw solid #1f2937; display: flex; align-items: center; border-radius: 0.5vw; margin-bottom: 1.5vw; box-shadow: 0 0.5vw 1vw rgba(0,0,0,0.3); }
        .toggle-btn { background: none; border: none; color: #e2e8f0; font-size: 1.5vw; cursor: pointer; transition: color 0.2s; }
        .toggle-btn:hover { color: #38bdf8; }
        /* Common styles for panels */
        .panel { background-color: #111827; box-shadow: 0 0.5vw 1vw rgba(0,0,0,0.4); border: 0.1vw solid #1f2937 !important; border-radius: 0.8vw !important; }
        .text-warning { color: #38bdf8 !important; }
        .text-info { color: #818cf8 !important; }
        .bg-dark { background-color: #1f2937 !important; }
        .btn-warning { background-color: #0ea5e9; border-color: #0ea5e9; color: #fff; }
        .btn-warning:hover { background-color: #0284c7; border-color: #0284c7; color: #fff; }
        .btn-outline-warning { border-color: #0ea5e9; color: #0ea5e9; }
        .btn-outline-warning:hover { background-color: #0ea5e9; color: #fff; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="sidebar" id="sidebar">
        <div class="p-3 mb-3 text-center border-bottom border-dark">
            <h4 class="text-warning fw-bold m-0">ANDON YÖNETİMİ</h4>
        </div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "DashboardaAktar" ? "active" : "")" href="/Home/DashboardaAktar">
                    <i class="bi bi-display me-2"></i> Dashboarda Aktar
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "SpTasarim" ? "active" : "")" href="/Home/SpTasarim">
                    <i class="bi bi-palette me-2"></i> SP Tasarım
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "SablonTasarim" ? "active" : "")" href="/Home/SablonTasarim">
                    <i class="bi bi-grid-1x2 me-2"></i> Şablon Tasarım
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "MakineSpEslesme" ? "active" : "")" href="/Home/MakineSpEslesme">
                    <i class="bi bi-link-45deg me-2"></i> Makine-SP Eşleştirme
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "SablonKayit" ? "active" : "")" href="/Home/SablonKayit">
                    <i class="bi bi-save me-2"></i> Şablon Kayıt
                </a>
            </li>
        </ul>
    </div>

    <div class="main-content d-flex flex-column" id="mainContent">
        <div class="topbar mb-4 rounded d-flex justify-content-between align-items-center">
            <div>
                <button class="toggle-btn" id="sidebarToggle"><i class="bi bi-list"></i></button>
            </div>
            <div>
                <h5 class="m-0 text-muted">@ViewData["Title"]</h5>
            </div>
        </div>

        <div class="flex-grow-1">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('sidebarToggle').addEventListener('click', function() {
            document.getElementById('sidebar').classList.toggle('collapsed');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
