@model AcdProject.Models.Entities.AndonViewModel
@{
    ViewData["Title"] = "Makine - SP Eşleştirme";
}

<div class="container-fluid">
    <h3 class="mb-4 text-warning">Adım 2: Eşleştirme</h3>
    <p class="text-muted">Bir önceki adımda seçtiğiniz makineler için uygun Stock Procedure (SP) tasarımlarını eşleştirin.</p>
    
    <div id="noDraftAlert" class="alert alert-danger d-none">
        Henüz bir şablon tasarımı başlatmadınız. Lütfen <a href="/Home/SablonTasarim" class="alert-link">Şablon Tasarım</a> sayfasına gidip makine seçimi yapın.
    </div>

    <div id="mappingContent" class="d-none">
        <div class="row">
            <div class="col-md-8">
                <div class="panel p-4 border border-secondary rounded">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="text-info m-0">Seçilen Makineler ve SP Atamaları</h5>
                        <span class="badge bg-secondary fs-6" id="layoutBadge"></span>
                    </div>
                    <div id="mappingArea" class="row g-3">
                        <!-- Mapping rows will be generated by JS -->
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="alert alert-info border-secondary bg-dark text-light">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Not:</strong> Eşleştirme işlemi bittikten sonra Şablon Kayıt ekranına geçebilirsiniz. SP tasarımlarını "SP Tasarım" menüsünden dilediğiniz zaman güncelleyebilirsiniz.
                </div>
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-between">
            <a href="/Home/SablonTasarim" class="btn btn-secondary px-5"><i class="bi bi-arrow-left"></i> Geri</a>
            <button id="btnNext" class="btn btn-warning px-5 fw-bold">İleri: Şablon Kayıt <i class="bi bi-arrow-right"></i></button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const procedures = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Procedures));
        
        document.addEventListener("DOMContentLoaded", () => {
            const draft = JSON.parse(sessionStorage.getItem("draftTemplate"));
            const andonSpDesigns = JSON.parse(localStorage.getItem("andonSpDesigns")) || {};
            
            if (!draft || !draft.selectedMachines || draft.selectedMachines.length === 0) {
                document.getElementById("noDraftAlert").classList.remove("d-none");
                return;
            }

            document.getElementById("mappingContent").classList.remove("d-none");
            document.getElementById("layoutBadge").innerText = `Layout: ${draft.layout}`;

            const mappingArea = document.getElementById("mappingArea");
            
            // Build SP options
            let spOptions = ``;
            // SP'leri listelerken, tasarımı yapılmış olanları vurgulayabiliriz
            procedures.forEach(p => {
                const isDesigned = andonSpDesigns[p.Id] || andonSpDesigns[p.Name] ? " (Tasarımı Var)" : "";
                spOptions += `<option value="${p.Id}">${p.Name}${isDesigned}</option>`;
            });

            draft.selectedMachines.forEach((machine, idx) => {
                const slotId = idx + 1;
                
                // Önceden yapılmış eşleşme varsa onu bul
                let preSelectedSps = [];
                if (draft.mapping) {
                    const existingMap = draft.mapping.find(m => m.machineId === machine.id);
                    if (existingMap) {
                        preSelectedSps = existingMap.spIds || (existingMap.spId ? [existingMap.spId] : []);
                    }
                }

                const slotHtml = `
                    <div class="col-md-6">
                        <div class="p-3 border border-secondary rounded bg-dark">
                            <h6 class="text-light">${machine.name}</h6>
                            <small class="text-muted" style="font-size: 0.75rem;">(Birden fazla seçmek için CTRL tuşuna basılı tutun)</small>
                            <input type="hidden" class="mapping-machine" data-slot="${slotId}" value="${machine.id}" />
                            <select class="form-select bg-dark text-light border-secondary mapping-sp mt-2" multiple size="3" data-slot="${slotId}">
                                ${spOptions}
                            </select>
                        </div>
                    </div>
                `;
                mappingArea.insertAdjacentHTML('beforeend', slotHtml);
                
                // Set pre-selected value
                if (preSelectedSps.length > 0) {
                    const select = mappingArea.querySelector(`.mapping-sp[data-slot="${slotId}"]`);
                    if (select) {
                        Array.from(select.options).forEach(opt => {
                            if (preSelectedSps.includes(opt.value)) {
                                opt.selected = true;
                            }
                        });
                    }
                }
            });

            document.getElementById("btnNext").addEventListener("click", () => {
                const mappings = [];
                let hasEmpty = false;

                document.querySelectorAll(".mapping-machine").forEach((machineInput) => {
                    const slotId = machineInput.getAttribute("data-slot");
                    const spSelect = document.querySelector(`.mapping-sp[data-slot="${slotId}"]`);
                    
                    const selectedSpIds = Array.from(spSelect.selectedOptions).map(opt => opt.value).filter(val => val !== "");
                    
                    if (selectedSpIds.length > 0) {
                        mappings.push({
                            slot: slotId,
                            machineId: machineInput.value,
                            spIds: selectedSpIds,
                            spId: selectedSpIds[0] // for backwards compatibility
                        });
                    } else {
                        hasEmpty = true;
                    }
                });

                if (mappings.length === 0) {
                    alert("Lütfen en az bir makine ile SP'yi eşleştirin.");
                    return;
                }
                
                if (hasEmpty) {
                    const confirmRes = confirm("Bazı makineler için SP seçmediniz. Devam etmek istiyor musunuz?");
                    if (!confirmRes) return;
                }

                // Taslağı güncelle
                draft.mapping = mappings;
                sessionStorage.setItem("draftTemplate", JSON.stringify(draft));
                
                window.location.href = "/Home/SablonKayit";
            });
        });
    </script>
}
