@model AcdProject.Models.Entities.AndonViewModel
@{
    ViewData["Title"] = "Makine - SP Eşleştirme";
}

<div class="container-fluid">
    <h3 class="mb-4 text-warning">Adım 2: Eşleştirme</h3>
    <p class="text-muted">Bir önceki adımda seçtiğiniz makineler için uygun Stock Procedure (SP) tasarımlarını eşleştirin.</p>
    
    <div id="noDraftAlert" class="alert alert-danger d-none">
        Henüz bir şablon tasarımı başlatmadınız. Lütfen <a href="/Home/SablonTasarim" class="alert-link">Şablon Tasarım</a> sayfasına gidip makine seçimi yapın.
    </div>

    <div id="mappingContent" class="d-none">
        <div class="row">
            <div class="col-md-8">
                <div class="panel p-4 border border-secondary rounded">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="text-info m-0">Seçilen Makineler ve SP Atamaları</h5>
                        <span class="badge bg-secondary fs-6" id="layoutBadge"></span>
                    </div>
                    <div id="mappingArea" class="row g-3">
                        <!-- Mapping rows will be generated by JS -->
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="alert alert-info border-secondary bg-dark text-light">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Not:</strong> Eşleştirme işlemi bittikten sonra Şablon Kayıt ekranına geçebilirsiniz. SP tasarımlarını "SP Tasarım" menüsünden dilediğiniz zaman güncelleyebilirsiniz.
                </div>
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-between">
            <a href="/Home/SablonTasarim" class="btn btn-secondary px-5"><i class="bi bi-arrow-left"></i> Geri</a>
            <button id="btnNext" class="btn btn-warning px-5 fw-bold">İleri: Şablon Kayıt <i class="bi bi-arrow-right"></i></button>
        </div>
    </div>
    <div id="procedures-data" data-procedures='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Procedures))' class="d-none"></div>
</div>

@section Scripts {
    <script src="/js/makine-sp-eslesme.js"></script>
}
