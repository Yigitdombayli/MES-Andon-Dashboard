@model AcdProject.Models.Entities.AndonViewModel 
@{ Layout = null; }
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Andon Dashboard Sihirbazı</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/gridstack@8.2.3/dist/gridstack.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/template.css" />
</head>
<body class="bg-dark text-light p-4">
    <div class="container-fluid wireframe-container p-4 border border-secondary rounded">
        
        <div id="step1">
            <h3 class="mb-4 text-warning">Adım 1: Layout Seçimi</h3>
            <p class="text-muted">Lütfen ekranda kaç makine göstermek istediğinizi ve düzenini seçin.</p>
            <div class="row">
                <div class="col-md-4">
                    <div class="panel p-3 border border-secondary rounded">
                        <div class="form-check mb-3">
                            <input class="form-check-input layout-radio" type="radio" name="layout" value="2x2" id="l1" />
                            <label class="form-check-label fs-5" for="l1">2x2 (4 Makine)</label>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input layout-radio" type="radio" name="layout" value="4x3" id="l2" />
                            <label class="form-check-label fs-5" for="l2">4x3 (12 Makine)</label>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input layout-radio" type="radio" name="layout" value="3x3" id="l3" />
                            <label class="form-check-label fs-5" for="l3">3x3 (9 Makine)</label>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input layout-radio" type="radio" name="layout" value="4x4" id="l4" />
                            <label class="form-check-label fs-5" for="l4">4x4 (16 Makine)</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="mt-4 text-end">
                <button id="btnNext1" class="btn btn-warning px-5">İleri: SP Tasarımına Geç</button>
            </div>
        </div>

        <div id="step2" class="d-none">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="text-warning m-0">Adım 2: SP Kartlarını Ayarlama</h3>
                <h5 class="m-0 text-info" id="selectedLayoutDisplay">Seçilen Layout: -</h5>
            </div>
            
            <div class="row h-100 g-4">
                <div class="col-md-3">
                    <div class="panel h-100 p-3 border border-secondary rounded">
                        <h5>Prosedürler (SP)</h5>
                        <div class="ProcedureList mt-4">
                            @foreach(var procedure in Model.Procedures) {
                                <div class="form-check mb-2">
                                    <input class="form-check-input procedure-radio" type="radio" name="selectedSp" value="@procedure.Name" id="@procedure.Id" />
                                    <label class="form-check-label" for="@procedure.Id">@procedure.Name</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-md-9 d-flex flex-column gap-3">
                    <div class="panel flex-grow-1 p-3 border border-secondary rounded">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="m-0">Tasarım Alanı</h5>
                            <button id="btnSaveSpDesign" class="btn btn-sm btn-success px-4">Bu SP'yi Hafızaya Al</button>
                        </div>
                        <div id="cardDesignerArea" class="grid-stack"></div>
                    </div>
                    
                    <div class="panel p-3 border border-secondary rounded">
                        <h5>SP Verileri</h5>
                        <div id="incomingDataPool" class="data-pool mt-2 min-h-50"></div>
                    </div>
                </div>
            </div>
            
            <div class="mt-4 d-flex justify-content-between">
                <button id="btnBack1" class="btn btn-secondary px-5">Geri</button>
                <button id="btnNext2" class="btn btn-warning px-5">İleri: Eşleştirme ve Kayıt</button>
            </div>
        </div>

        <div id="step3" class="d-none">
            <h3 class="mb-4 text-warning">Adım 3: Makine - SP Eşleştirme ve Şablon Kaydı</h3>
            <p class="text-muted">Seçtiğiniz layout kapasitesine göre makineleri ve tasarladığınız SP'leri eşleştirip kaydedin.</p>
            
            <div class="row">
                <div class="col-md-8">
                    <div id="mappingArea" class="row g-3"></div>
                </div>
                
                <div class="col-md-4">
                    <div class="panel p-3 border border-secondary rounded">
                        <h5 class="mb-3">Şablonu Kaydet</h5>
                        <div class="mb-3">
                            <label class="form-label">Şablon Adı:</label>
                            <input type="text" id="templateNameInput" class="form-control bg-dark text-light border-secondary" placeholder="Örn: Vardiya 1 Şablonu" />
                        </div>
                        <button id="btnSaveFinalTemplate" class="btn btn-success w-100">Şablonu Kaydet ve Bitir</button>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <button id="btnBack2" class="btn btn-secondary px-5">Geri</button>
            </div>
        </div>

    </div>

    <script>
        const procedures = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Procedures));
        const machines = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Machines));
    </script>
    <script src="https://cdn.jsdelivr.net/npm/gridstack@8.2.3/dist/gridstack-all.js"></script>
    <script src="/wizard.js"></script>
</body>
</html>