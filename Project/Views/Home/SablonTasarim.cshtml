@model AcdProject.Models.Entities.AndonViewModel
@{
    ViewData["Title"] = "Şablon Tasarım";
}

<div class="container-fluid">
    <h3 class="mb-4 text-warning">Adım 1: Layout ve Makine Seçimi</h3>
    <p class="text-muted">Lütfen ekranda kaç makine göstermek istediğinizi (layout) ve şablonda yer alacak makineleri seçin.</p>
    
    <div class="row">
        <div class="col-md-4">
            <div class="panel p-3 border border-secondary rounded h-100">
                <h5 class="text-info mb-3">Layout Seçimi</h5>
                <div class="form-check mb-3">
                    <input class="form-check-input layout-radio" type="radio" name="layout" value="2x2" id="l1" />
                    <label class="form-check-label fs-5" for="l1">2x2 (4 Makine)</label>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input layout-radio" type="radio" name="layout" value="4x3" id="l2" />
                    <label class="form-check-label fs-5" for="l2">4x3 (12 Makine)</label>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input layout-radio" type="radio" name="layout" value="3x3" id="l3" />
                    <label class="form-check-label fs-5" for="l3">3x3 (9 Makine)</label>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input layout-radio" type="radio" name="layout" value="4x4" id="l4" />
                    <label class="form-check-label fs-5" for="l4">4x4 (16 Makine)</label>
                </div>
            </div>
        </div>
        
        <div class="col-md-8">
            <div class="panel p-3 border border-secondary rounded h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="text-info m-0">Makine Seçimi <span id="capacityInfo" class="text-warning fs-6"></span></h5>
                    <button type="button" class="btn btn-sm btn-outline-warning" id="selectAllBtn">Tümünü Seç</button>
                </div>
                <div class="alert alert-dark border-secondary p-2 small mb-3">
                    <i class="bi bi-info-circle text-info"></i> İpucu: Layout kapasitesinden daha az makine seçebilirsiniz. Kalan slotlar ekranda boş bırakılır.
                </div>
                <div class="row" id="machineListContainer">
                    @foreach (var machine in Model.Machines)
                    {
                        <div class="col-md-4 mb-2">
                            <div class="form-check">
                                <input class="form-check-input machine-checkbox" type="checkbox" value="@machine.Id" id="mac_@machine.Id" data-name="@machine.Name">
                                <label class="form-check-label" for="mac_@machine.Id">
                                    @machine.Name
                                </label>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-4 text-end">
        <button id="btnNext" class="btn btn-warning px-5 fw-bold">İleri: Eşleştirme <i class="bi bi-arrow-right"></i></button>
    </div>
</div>

@section Scripts {
    <script src="/js/sablon-tasarim.js"></script>
}
