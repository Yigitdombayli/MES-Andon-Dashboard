@{ Layout = null; }
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ANDON Şablon Yönetimi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-dark text-light p-5">
    <div class="container">
        <h2 class="mb-4 text-warning">Kayıtlı Şablonlar</h2>
        <p class="text-muted">Dashboard ekranında dönmesini istediğiniz şablonları seçin ve yayına alın.</p>
        
        <div class="row">
            <div class="col-md-8">
                <div class="panel p-4 border border-secondary rounded bg-body-tertiary text-dark">
                    <form id="templateSelectionForm">
                        <div id="templateListArea" class="row g-3">
                            </div>
                        <div class="mt-4 text-end">
                            <button type="button" id="btnStartDashboard" class="btn btn-warning px-5 fw-bold">Dashboard'u Başlat</button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="col-md-4">
                <div class="alert alert-info">
                    <strong>Bilgi:</strong> Birden fazla şablon seçerseniz, dashboard ekranı bu şablonlar arasında 60 saniyede bir otomatik geçiş yapacaktır.
                </div>
                <a href="/Home/Wizard" class="btn btn-outline-light w-100">Yeni Şablon Tasarla (Sihirbaz)</a>
            </div>
        </div>
    </div>

    <script src="/app.js"></script>
</body>
</html>