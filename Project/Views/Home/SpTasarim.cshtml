@model AcdProject.Models.Entities.AndonViewModel
@{
    ViewData["Title"] = "SP Tasarım";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-warning m-0">SP Kartlarını Ayarlama</h3>
    </div>
    
    <div class="row h-100 g-4">
        <div class="col-md-3">
            <div class="panel h-100 p-3 border border-secondary rounded">
                <h5>Prosedürler (SP)</h5>
                <p class="text-muted small">Düzenlemek istediğiniz prosedürü seçin.</p>
                <div class="ProcedureList mt-4">
                    @foreach(var procedure in Model.Procedures) {
                        <div class="form-check mb-2">
                            <input class="form-check-input procedure-radio" type="radio" name="selectedSp" value="@procedure.Name" id="@procedure.Id" />
                            <label class="form-check-label" for="@procedure.Id">@procedure.Name</label>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-9 d-flex flex-column gap-3">
            <div class="panel flex-grow-1 p-3 border border-secondary rounded">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="m-0">Tasarım Alanı</h5>
                    <button id="btnSaveSpDesign" class="btn btn-sm btn-success px-4">Tasarımı Global Kaydet</button>
                </div>
                <div id="cardDesignerArea" class="grid-stack"></div>
            </div>
            
            <div class="panel p-3 border border-secondary rounded">
                <h5>SP Verileri</h5>
                <div id="incomingDataPool" class="data-pool mt-2 min-h-50 d-flex flex-wrap gap-2"></div>
            </div>
        </div>
    </div>
    <div id="procedures-data" data-procedures='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Procedures))' class="d-none"></div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/gridstack@8.2.3/dist/gridstack-all.js"></script>
    <script src="/js/sp-tasarim.js"></script>
}
