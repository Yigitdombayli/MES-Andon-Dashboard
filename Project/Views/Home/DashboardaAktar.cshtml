@{
    ViewData["Title"] = "Dashboarda Aktar";
}

<div class="container-fluid">
    <h2 class="mb-4 text-warning">Kayıtlı Şablonlar</h2>
    <p class="text-muted">Dashboard ekranında dönmesini istediğiniz şablonları seçin ve yayına alın.</p>
    
    <div class="row">
        <div class="col-md-8">
            <div class="panel p-4 border border-secondary rounded">
                <form id="templateSelectionForm">
                    <div id="templateListArea" class="row g-3">
                        <!-- Templates will be loaded here via JS -->
                    </div>
                    <div class="mt-4 text-end">
                        <button type="button" id="btnStartDashboard" class="btn btn-warning px-5 fw-bold">Dashboard'u Başlat</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="col-md-4">
            <div class="alert alert-info border-secondary bg-dark text-light">
                <i class="bi bi-info-circle me-2"></i>
                <strong>Bilgi:</strong> Birden fazla şablon seçerseniz, dashboard ekranı bu şablonlar arasında belirlediğiniz sürede bir otomatik geçiş yapacaktır.
            </div>
            <div class="panel p-3 border border-secondary rounded mb-3 bg-dark">
                <label for="rotationInterval" class="form-label text-warning fw-bold">Şablon Geçiş Süresi (Saniye)</label>
                <div class="input-group">
                    <input type="number" id="rotationInterval" class="form-control bg-dark text-light border-secondary" value="30" min="5" step="1">
                    <span class="input-group-text bg-secondary text-light border-secondary">Sn</span>
                </div>
                <small class="text-muted mt-2 d-block">Şablonlar arası ve makine içi SP rotasyon sürelerini belirler.</small>
            </div>
            <a href="/Home/SablonTasarim" class="btn btn-outline-light w-100">Yeni Şablon Tasarla</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="/js/dashboarda-aktar.js"></script>
}
